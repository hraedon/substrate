{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Substrate Workflow Definition",
  "type": "object",
  "required": [
    "name",
    "version",
    "substrate_version",
    "states",
    "transitions",
    "roles",
    "work_item_types"
  ],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "substrate_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9._-]+)?(\\+[a-zA-Z0-9._-]+)?$"
    },
    "states": {
      "type": "array",
      "minItems": 1,
      "contains": {
        "type": "object",
        "required": [
          "initial"
        ],
        "properties": {
          "initial": {
            "const": true
          }
        }
      },
      "minContains": 1,
      "maxContains": 1,
      "items": {
        "type": "object",
        "required": [
          "name"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "initial": {
            "type": "boolean",
            "default": false
          },
          "terminal": {
            "type": "boolean",
            "default": false
          }
        }
      }
    },
    "transitions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "from",
          "to"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "from": {
            "type": "string",
            "minLength": 1
          },
          "to": {
            "type": "string",
            "minLength": 1
          },
          "allowed_roles": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "validator": {
            "type": "string"
          },
          "hooks": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          }
        }
      }
    },
    "roles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "work_item_types": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "custom_fields"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "custom_fields": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "name",
                "type"
              ],
              "additionalProperties": false,
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 1
                },
                "type": {
                  "type": "string",
                  "enum": [
                    "string",
                    "integer",
                    "boolean",
                    "timestamp",
                    "json",
                    "enum",
                    "work_item_ref"
                  ]
                },
                "required": {
                  "type": "boolean",
                  "default": false
                },
                "default": {},
                "ui_visible": {
                  "type": "boolean",
                  "default": false
                },
                "enum_values": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "target_work_item_type": {
                  "type": "string"
                }
              },
              "allOf": [
                {
                  "if": {
                    "properties": {
                      "type": {
                        "const": "enum"
                      }
                    },
                    "required": [
                      "type"
                    ]
                  },
                  "then": {
                    "required": [
                      "enum_values"
                    ]
                  }
                },
                {
                  "if": {
                    "properties": {
                      "type": {
                        "const": "work_item_ref"
                      }
                    },
                    "required": [
                      "type"
                    ]
                  },
                  "then": {
                    "required": [
                      "target_work_item_type"
                    ]
                  }
                }
              ]
            }
          }
        }
      }
    },
    "link_types": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "source_type",
          "target_type"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "source_type": {
            "type": "string",
            "minLength": 1
          },
          "target_type": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "attempt_threshold": {
      "type": "integer",
      "minimum": 1
    },
    "hook_defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_retries": {
          "type": "integer",
          "default": 3
        },
        "retry_backoff_seconds": {
          "type": "number",
          "default": 5
        }
      }
    }
  }
}
